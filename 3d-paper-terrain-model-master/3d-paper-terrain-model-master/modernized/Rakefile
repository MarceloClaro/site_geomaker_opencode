# frozen_string_literal: true

begin
  require 'bundler/setup' # carrega as versoes travadas em Gemfile.lock, se presente
rescue LoadError
  warn '[aviso] bundler nao disponivel neste ambiente; usando gems instaladas globalmente.'
end

require 'rake/testtask'

Rake::TestTask.new(:test) do |t|
  t.libs << 'test' << 'lib'
  t.test_files = FileList['test/test_*.rb']
  t.verbose = true
  t.warning = false
end

task default: :test

desc 'Roda o modelo com os parametros default (maciço de Poľana, identico ao Ciclo 1)'
task :run do
  sh 'ruby 3d-paper-model.rb'
end

desc 'Mostra a ajuda completa da CLI (todas as opcoes disponiveis)'
task :help do
  sh 'ruby 3d-paper-model.rb --help'
end

desc 'Smoke test rapido: roda com grade reduzida (10x8) para validar o pipeline de ponta a ponta sem esperar minutos'
task :smoke do
  require 'tmpdir'
  Dir.mktmpdir do |dir|
    out = File.join(dir, 'smoke.svg')
    sh "ruby 3d-paper-model.rb --lat-steps 10 --lon-steps 8 --out #{out}"
    if File.exist?(out) && File.size(out) > 0
      puts "\n[smoke] OK — #{out} gerado com #{File.size(out)} bytes."
    else
      raise '[smoke] FALHOU — arquivo de saida nao foi gerado ou esta vazio.'
    end
  end
end

desc 'Verifica a sintaxe de todos os arquivos .rb do projeto (sem executar)'
task :syntax_check do
  files = FileList['*.rb', 'lib/*.rb', 'test/*.rb']
  failures = []
  files.each do |f|
    ok = system("ruby -c #{f} > /dev/null 2>&1")
    failures << f unless ok
  end
  if failures.empty?
    puts "[syntax_check] OK — #{files.size} arquivos com sintaxe valida."
  else
    raise "[syntax_check] FALHOU em: #{failures.join(', ')}"
  end
end

desc 'Verificacao completa de saude do projeto: sintaxe + testes + smoke test (equivalente a "esta pronto para execucao?")'
task doctor: %i[syntax_check test smoke] do
  puts "\n=================================================="
  puts ' DOCTOR: projeto pronto para execucao. Tudo OK.'
  puts '=================================================='
end

namespace :run do
  desc 'Exemplo: gera modelo do Grand Canyon (grade reduzida, rapido)'
  task :grand_canyon do
    sh 'ruby 3d-paper-model.rb --bbox "36.05,-112.20,36.15,-112.05" --lat-steps 12 --lon-steps 8 --out grand_canyon.svg'
  end

  desc 'Exemplo: gera modelo do Monte Fuji via geocoding por nome (grade reduzida, rapido)'
  task :fuji do
    sh 'ruby 3d-paper-model.rb --place "Mount Fuji, Japan" --size-km 20 --lat-steps 12 --lon-steps 8 --out mount_fuji.svg'
  end
end
